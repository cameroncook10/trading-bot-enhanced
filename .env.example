# Backend Configuration
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:3000

# Frontend Configuration (in frontend/.env)
REACT_APP_API_URL=http://localhost:5000
REACT_APP_SOCKET_URL=http://localhost:5000

# Trading API Keys (when integrating with real APIs)
# KRAKEN_API_KEY=your_key_here
# KRAKEN_API_SECRET=your_secret_here
# POLYMARKET_API_KEY=your_key_here

# Database Configuration (when ready to persist data)
# DATABASE_URL=mongodb://localhost:27017/trading-agent
# or
# DATABASE_URL=postgresql://user:password@localhost:5432/trading_agent

# Email Configuration (for notifications)
# SENDGRID_API_KEY=your_key_here
# NOTIFICATION_EMAIL=your_email@example.com

# OpenAI/Claude API (for AI decision making)
# OPENAI_API_KEY=your_key_here
# ANTHROPIC_API_KEY=your_key_here
